# 服务运行端口，默认 80
PORT=80

# 微信公众号配置 (需在微信公众号后台获取)
WECHAT_TOKEN=your_wechat_token_here
WECHAT_APPID=your_wechat_appid_here
WECHAT_APP_SECRET=your_wechat_app_secret_here
WECHAT_ENCODING_AES_KEY=your_wechat_encoding_aes_key_here

# 扫车 API 配置 (通过抓包获取)
# 实测此接口不验证 TOKEN ，如果无法抓包取得随便填也没关系
API_URL=https://api.kvcoogo.com/ManagerApi/api/v1.0.0/queryNearbyCar
API_TOKEN=your_api_token_here
